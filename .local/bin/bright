#!/usr/bin/sh
wobfifo="/tmp/wob.fifo"

blocks_reload() {
    kill -36 $(pgrep -x damblocks)
}

bright_parse() {
    grep 'Current brightness' | tr '()' ' ' | cut -d' ' -f5 | sed 's/%//' > $wobfifo;
}

bright_minus() {
    brightnessctl set 1%- | bright_parse
    blocks_reload
}

bright_plus() {
    brightnessctl set 1%+ | bright_parse
    blocks_reload
}

while [ -n "$1" ]; do
    case "$1" in
        --minus)
            bright_minus
            ;;
        --plus)
            bright_plus
            ;;
    esac
    shift
done
